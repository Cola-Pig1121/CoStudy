# ─────────────────────────────────────────────
# CoStudy 后端环境变量模板
# 复制为 .env 并按实际环境填写
# ─────────────────────────────────────────────

# 应用
APP_NAME=CoStudy API
APP_VERSION=0.1.0
DEBUG=true

# 数据库 (PostgreSQL + pgvector)
DATABASE_URL=postgresql+asyncpg://costudy:costudy@localhost:5432/costudy

# Redis (缓存 / Celery broker / 限流)
REDIS_URL=redis://localhost:6379/0

# MinIO 对象存储
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=costudy
MINIO_SECURE=false

# JWT 认证
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# CORS（多个用逗号分隔）
CORS_ORIGINS=http://localhost:3000

# Embedding (RAG) - 使用本地 text2vec-base-chinese (768维)
EMBEDDING_MODEL=shibing624/text2vec-base-chinese
EMBEDDING_DIMENSIONS=768

# 限流
RATE_LIMIT_AI_PER_MINUTE=5
RATE_LIMIT_OCR_PER_MINUTE=2